# Application
DEBUG=true
ENVIRONMENT=development
APP_NAME=AutoMind AI Platform
APP_VERSION=0.1.0

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# Database (RDS PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/automind
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# DynamoDB
DYNAMODB_TABLE_NAME=automind_sessions

# S3
S3_ASSETS_BUCKET=automind-assets
S3_TOUR_SCRIPTS_BUCKET=automind-tour-scripts

# Cognito
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# JWT
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24

# SQS
SQS_PROCESSING_QUEUE_URL=

# Gupshup (WhatsApp)
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
